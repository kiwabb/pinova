.tab-shell { position: fixed; z-index: 100; left: 0; right: 0; bottom: 0; padding-bottom: env(safe-area-inset-bottom); border-top: 1rpx solid rgba(225,76,125,.1); background: rgba(255,255,255,.94); box-shadow: 0 -10rpx 32rpx rgba(91,58,70,.08); backdrop-filter: blur(22rpx); }
.tab-bar { height: 116rpx; padding: 8rpx 17rpx; display: grid; grid-template-columns: repeat(5, 1fr); background: transparent; }
.tab-item { position: relative; min-width: 0; padding-bottom: 4rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; color: #817b81; font-size: 19rpx; font-weight: 400; transition: opacity .18s ease; }
.tab-item.active { color: #e14c7d; }
.tab-item.tab-pressed { opacity: .58; }
.tab-icon { width: 40rpx; height: 40rpx; }
.tab-indicator { position: absolute; left: 50%; bottom: -2rpx; width: 24rpx; height: 5rpx; border-radius: 999rpx; background: linear-gradient(90deg, #e14c7d 0%, #f0848b 100%); transform: translateX(-50%); box-shadow: 0 3rpx 8rpx rgba(225,76,125,.22); }
