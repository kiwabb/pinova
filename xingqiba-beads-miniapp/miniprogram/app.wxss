page {
  --page-bg: #fff8fa;
  --surface: rgba(255, 255, 255, .82);
  --surface-strong: rgba(255, 255, 255, .94);
  --text: #1d1b1d;
  --muted: #8d888d;
  --weak: #9d969c;
  --line: rgba(232, 215, 222, .58);
  --border: rgba(255, 255, 255, .78);
  --control-border: rgba(233, 216, 223, .78);
  --primary: #e14c7d;
  --primary-end: #f0848b;
  --primary-pressed: #d63e70;
  --primary-soft: #fceff3;
  --brand-cream: #fff8fa;
  --brand-blush: #f8b4c8;
  --pink-shadow: rgba(225, 76, 125, .1);
  min-height: 100%;
  background:
    radial-gradient(circle at 88% 4%, rgba(248, 180, 200, .34) 0, rgba(248, 180, 200, 0) 32%),
    linear-gradient(160deg, #fffdfc 0%, var(--page-bg) 50%, #fdf7f8 100%);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 24rpx;
}

view, text, image, button, input, scroll-view, canvas { box-sizing: border-box; }
button { width: auto; min-width: 0; margin: 0; padding: 0; line-height: inherit; }
button::after { border: 0; }
image { display: block; }

.page { min-height: 100vh; padding: 46rpx 40rpx 220rpx; }
.section { margin-top: 46rpx; }
.section-head { min-height: 85rpx; display: flex; align-items: center; justify-content: space-between; gap: 23rpx; }
.section-title { font-size: 31rpx; font-weight: 500; line-height: 1.2; }
.section-action { min-height: 85rpx; display: flex; align-items: center; gap: 4rpx; color: var(--weak); font-size: 23rpx; font-weight: 400; }
.card { background: var(--surface); border: 1rpx solid var(--border); border-radius: 31rpx; box-shadow: 0 16rpx 46rpx var(--pink-shadow); }
.muted { color: var(--muted); }
.primary-button { width: 100% !important; min-width: 0 !important; height: 108rpx; display: flex; align-items: center; justify-content: center; gap: 10rpx; border: 0; border-radius: 31rpx; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 27rpx; font-weight: 700; box-shadow: 0 13rpx 28rpx rgba(225, 76, 125, .2); }
.primary-button.button-hover { background: linear-gradient(105deg, var(--primary-pressed) 0%, #e9707d 100%); }
.primary-button[disabled] { background: #e9e5e8; color: #a39da2; box-shadow: none; opacity: 1; }
.icon { width: 35rpx; height: 35rpx; flex: none; }
.icon-small { width: 21rpx; height: 21rpx; flex: none; }
.empty { padding: 70rpx 24rpx; color: var(--muted); text-align: center; }
