.detail-page { padding-top: 46rpx; padding-bottom: 42rpx; }
.detail-state { min-height: 300rpx; padding: 40rpx; display: flex; align-items: center; justify-content: center; color: #858189; font-size: 25rpx; text-align: center; }.detail-state.error-state { flex-direction: column; gap: 20rpx; color: #9f2d25; }.detail-state button { min-width: 130rpx !important; min-height: 76rpx; padding: 0 24rpx; border-radius: 23rpx; background: #fceff4; color: #c42d5d; font-size: 25rpx; font-weight: 700; }
.summary { min-height: 164rpx; margin-bottom: 27rpx; padding: 31rpx; display: flex; align-items: center; justify-content: space-between; gap: 27rpx; }
.summary-copy { min-width: 0; }.summary-title { min-width: 0; display: flex; align-items: center; gap: 12rpx; }.summary-title > text:first-child { overflow: hidden; font-size: 38rpx; font-weight: 700; line-height: 1.2; text-overflow: ellipsis; white-space: nowrap; }
.summary-desc { display: block; margin-top: 10rpx; overflow: hidden; color: #858189; font-size: 25rpx; line-height: 1.5; text-overflow: ellipsis; white-space: nowrap; }
.private { flex: none; min-height: 46rpx; padding: 0 13rpx; display: flex; align-items: center; border-radius: 999rpx; background: #fceff4; color: #c42d5d; font-size: 19rpx; font-weight: 700; }
.total { flex: none; color: #c42d5d; font-size: 46rpx; font-weight: 800; font-variant-numeric: tabular-nums; }.total small { margin-left: 6rpx; color: #858189; font-size: 23rpx; font-weight: 400; }
.toolbar { min-height: 92rpx; display: flex; align-items: center; justify-content: space-between; gap: 23rpx; color: #858189; font-size: 25rpx; }
.toolbar button { width: 120rpx !important; min-width: 120rpx !important; min-height: 85rpx; margin-left: auto; padding: 0; display: flex; align-items: center; justify-content: flex-end; gap: 8rpx; background: transparent; color: #c42d5d; font-size: 25rpx; font-weight: 650; }.toolbar image { width: 31rpx; height: 31rpx; }
.pattern-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24rpx; }
.pattern { position: relative; width: 100%; min-width: 0; overflow: hidden; color: #1f1e25; text-align: left; border-radius: 23rpx; }.pattern-media { position: relative; }.pattern-art { width: 100%; height: 286rpx; border-radius: 23rpx 23rpx 0 0; }.pattern-level { position: absolute; top: 12rpx; left: 12rpx; min-width: 54rpx; height: 38rpx; padding: 0 10rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #c42d5d; color: #fff; font-size: 18rpx; font-weight: 700; box-shadow: 0 5rpx 12rpx rgba(31, 30, 37, .14); }.pattern > text { display: block; padding: 18rpx 17rpx 20rpx; overflow: hidden; font-size: 25rpx; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }
.favorite-button { position: absolute; top: 10rpx; right: 10rpx; width: 68rpx !important; min-width: 68rpx !important; height: 68rpx; border: 1rpx solid rgba(236, 238, 241, .92); border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255, 255, 255, .94); box-shadow: 0 5rpx 15rpx rgba(31, 30, 37, .08); }.favorite-button image { width: 31rpx; height: 31rpx; }.favorite-button[disabled] { opacity: .55; }
.pattern-pressed { opacity: .72; }.rights-note { margin-top: 27rpx; padding: 23rpx 27rpx; border-left: 6rpx solid #c42d5d; background: #fceff4; color: #858189; font-size: 23rpx; line-height: 1.55; }
