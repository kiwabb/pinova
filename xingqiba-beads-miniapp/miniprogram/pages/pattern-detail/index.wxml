<view class="page pattern-detail-page">
  <view wx:if="{{loading}}" class="detail-state card">正在加载图纸</view>
  <view wx:elif="{{loadError}}" class="detail-state error-state card"><text>{{loadError}}</text><button bindtap="retry">重试</button></view>
  <block wx:elif="{{pattern && collection}}">
    <view class="pattern-hero card">
      <image class="hero-image" src="{{pattern.image}}" mode="aspectFill" />
      <button class="share-button" open-type="share" aria-label="分享图纸"><image src="/assets/icons/text/share-2.svg" /></button>
      <text wx:if="{{pattern.level !== '公开'}}" class="level-badge">{{pattern.level}} 专属</text>
    </view>

    <view class="pattern-overview card">
      <view class="title-row"><view><text class="pattern-kicker">{{collection.title}}</text><text class="pattern-title">{{pattern.name}}</text></view><text class="category-badge">{{collection.category}}</text></view>
      <view class="tag-row"><text>新手友好</text><text>{{gridSize}} × {{gridSize}}</text></view>
      <view class="pattern-metrics">
        <view><small>拼豆用量</small><text>{{beadSummary}}</text></view>
        <view><small>材料种类</small><text>{{materialCount}} 项</text></view>
        <view><small>底板用量</small><text>{{boardSummary}}</text></view>
      </view>
      <button class="open-button" bindtap="openPattern">打开图纸</button>
      <button class="favorite-action {{favorite ? 'active' : ''}}" disabled="{{favoriteBusy}}" loading="{{favoriteBusy}}" bindtap="toggleFavorite"><image src="{{favorite ? '/assets/icons/primary/heart.svg' : '/assets/icons/muted/heart.svg'}}" /><text>{{favorite ? '已收藏' : '收藏图纸'}}</text></button>
    </view>

    <view class="material-card card">
      <view class="material-head"><view><text>材料清单</text><small>按本图纸配置准备</small></view><text>{{materialCount}} 项</text></view>
      <view class="material-list">
        <view wx:for="{{pattern.materials}}" wx:key="id"><view class="material-dot {{item.kind}}"></view><view><text>{{item.name}}</text><small>{{item.description || '按图纸配置准备'}}</small></view><b>{{item.amount}} {{item.unit}}</b></view>
      </view>
      <view class="store-link" bindtap="openStore"><view><text>缺少材料？</text><small>前往星期八门店体验或配齐</small></view><text class="store-action">查看门店 ›</text></view>
    </view>
    <text class="detail-note">页面显示建议材料；打开图纸后的颜色和颗数统计用于实际配色</text>
  </block>
</view>
