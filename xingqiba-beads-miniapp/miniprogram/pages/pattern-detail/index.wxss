.pattern-detail-page { padding-top: 38rpx; padding-bottom: 100rpx; }
.detail-state { min-height: 280rpx; padding: 36rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx; color: var(--muted); font-size: 22rpx; text-align: center; }
.detail-state.error-state { background: #fff0ef; color: #9f2d25; }
.detail-state button { min-width: 118rpx !important; min-height: 68rpx; padding: 0 22rpx; border-radius: 21rpx; background: #fff; color: #e14c7d; font-size: 21rpx; font-weight: 650; }

.pattern-hero { position: relative; height: 620rpx; overflow: hidden; border-radius: 31rpx; }
.hero-image { width: 100%; height: 620rpx; }
.share-button { position: absolute; top: 21rpx; right: 21rpx; width: 66rpx !important; min-width: 66rpx !important; height: 66rpx; padding: 0; border: 1rpx solid rgba(236,238,241,.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.94); box-shadow: 0 6rpx 18rpx rgba(31,30,37,.1); }
.share-button image { width: 30rpx; height: 30rpx; }
.level-badge { position: absolute; left: 21rpx; bottom: 20rpx; padding: 8rpx 15rpx; border-radius: 999rpx; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 17rpx; font-weight: 700; box-shadow: 0 6rpx 16rpx rgba(225,76,125,.18); }

.pattern-overview { margin-top: 18rpx; padding: 29rpx 27rpx 27rpx; }
.title-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.title-row > view { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; }
.pattern-kicker { color: #e14c7d; font-size: 17rpx; font-weight: 700; letter-spacing: 1rpx; }
.pattern-title { max-width: 100%; margin-top: 8rpx; overflow: hidden; color: #252126; font-size: 38rpx; font-weight: 600; line-height: 1.25; text-overflow: ellipsis; white-space: nowrap; }
.category-badge { flex: none; padding: 7rpx 12rpx; border-radius: 999rpx; background: #f5f4f6; color: #77737b; font-size: 16rpx; }
.tag-row { margin-top: 19rpx; display: flex; gap: 10rpx; }
.tag-row text { padding: 7rpx 16rpx; border: 1rpx solid #dfb1c1; border-radius: 999rpx; color: #a52a54; font-size: 18rpx; }
.pattern-metrics { margin-top: 27rpx; padding: 21rpx 0; border-top: 1rpx solid var(--line); border-bottom: 1rpx solid var(--line); display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); }
.pattern-metrics > view { min-width: 0; display: flex; flex-direction: column; align-items: center; gap: 7rpx; text-align: center; }
.pattern-metrics > view + view { border-left: 1rpx solid var(--line); }
.pattern-metrics small { color: var(--weak); font-size: 17rpx; }
.pattern-metrics text { color: #39353c; font-size: 20rpx; font-weight: 600; white-space: nowrap; }
.open-button { width: 100% !important; height: 92rpx; margin-top: 26rpx; border: 0; border-radius: 25rpx; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 25rpx; font-weight: 700; line-height: 92rpx; box-shadow: 0 12rpx 26rpx rgba(225,76,125,.2); }
.favorite-action { width: 100% !important; height: 82rpx; margin-top: 12rpx; border: 1rpx solid #e6bdcb; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; gap: 9rpx; background: #fff; color: #e14c7d; font-size: 22rpx; font-weight: 600; }
.favorite-action image { width: 28rpx; height: 28rpx; }
.favorite-action.active { background: #fff7fa; }
.favorite-action[disabled] { opacity: .55; }

.material-card { margin-top: 20rpx; padding: 27rpx; }
.material-head { padding-bottom: 18rpx; display: flex; align-items: center; justify-content: space-between; gap: 15rpx; }
.material-head > view { display: flex; flex-direction: column; gap: 5rpx; }
.material-head > view > text { color: #2d2930; font-size: 29rpx; font-weight: 600; }
.material-head small { color: var(--weak); font-size: 18rpx; }
.material-head > text { padding: 6rpx 11rpx; border-radius: 999rpx; background: #f5f4f6; color: var(--muted); font-size: 16rpx; }
.material-list { border-top: 1rpx solid var(--line); }
.material-list > view { min-height: 88rpx; display: grid; grid-template-columns: 44rpx minmax(0,1fr) auto; align-items: center; gap: 13rpx; border-bottom: 1rpx solid var(--line); }
.material-dot { width: 38rpx; height: 38rpx; border-radius: 12rpx; }
.material-dot.board { border: 2rpx solid #d7d8dc; background: repeating-linear-gradient(0deg,#fff 0 7rpx,var(--control-border) 7rpx 9rpx); }
.material-dot.beads { background: #f3b9ca; box-shadow: inset 0 0 0 8rpx #e14c7d; border-radius: 50%; }
.material-dot.paper { border: 1rpx solid #e1d9ce; background: #fffaf1; }
.material-dot.other { border: 1rpx solid rgba(225,76,125,.18); background: linear-gradient(135deg,#fceff3,#fff8fa); }
.material-list > view > view:nth-child(2) { min-width: 0; display: flex; flex-direction: column; gap: 3rpx; }
.material-list text { color: #39353c; font-size: 21rpx; font-weight: 600; }
.material-list small { color: var(--weak); font-size: 16rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.material-list b { color: #5f5b62; font-size: 19rpx; font-weight: 600; white-space: nowrap; }
.store-link { min-height: 84rpx; margin-top: 19rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.store-link > view { min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.store-link > view text { color: #39353c; font-size: 20rpx; font-weight: 600; }
.store-link small { color: var(--weak); font-size: 16rpx; }
.store-action { flex: none; color: #e14c7d; font-size: 19rpx; font-weight: 600; }
.detail-note { display: block; padding: 22rpx 20rpx 0; color: #a09da4; font-size: 17rpx; line-height: 1.5; text-align: center; }
