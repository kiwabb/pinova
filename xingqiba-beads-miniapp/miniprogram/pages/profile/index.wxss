.profile-page { padding-top: 38rpx; }
.profile-intro { padding: 10rpx 4rpx 28rpx; display: flex; flex-direction: column; align-items: flex-start; }
.profile-kicker { color: #e14c7d; font-size: 19rpx; font-weight: 700; letter-spacing: 3rpx; }
.profile-intro-title { margin-top: 10rpx; color: var(--text); font-size: 38rpx; font-weight: 600; line-height: 1.2; }
.profile-intro-desc { margin-top: 10rpx; color: var(--weak); font-size: 21rpx; line-height: 1.45; }
.load-error { min-height: 74rpx; margin-top: 18rpx; padding: 15rpx 20rpx; border-radius: 21rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; background: #fff0ef; color: #9f2d25; font-size: 20rpx; }.load-error button { min-width: 78rpx !important; min-height: 56rpx; padding: 0 16rpx; border-radius: 17rpx; background: #fff; color: #9f2d25; font-size: 19rpx; font-weight: 700; }
.member-strip { min-height: 170rpx; margin-top: 0; padding: 27rpx 28rpx; border: 1rpx solid #40363c; border-radius: 29rpx; display: grid; grid-template-columns: 62rpx minmax(0,1fr) auto; align-items: center; gap: 17rpx; background: linear-gradient(135deg,#272329,#44333b); color: #fff; box-shadow: 0 16rpx 38rpx rgba(31,30,37,.12); }.member-brand { width: 62rpx; height: 62rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,.2)); }.member-main { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; }.member-kicker { color: #fed2c7; font-size: 14rpx; font-weight: 700; letter-spacing: 2rpx; }.member-title { margin-top: 8rpx; font-size: 28rpx; font-weight: 600; }.member-main small { margin-top: 8rpx; overflow: hidden; color: #cfc4c9; font-size: 18rpx; text-overflow: ellipsis; white-space: nowrap; }.member-summary { min-width: 92rpx; display: grid; grid-template-columns: 1fr 24rpx; grid-template-rows: auto auto; align-items: center; column-gap: 4rpx; text-align: right; }.member-summary small { grid-column: 1 / -1; color: #bbaeb4; font-size: 15rpx; }.member-summary > text:not(.member-arrow) { color: #fff; font-size: 29rpx; font-weight: 650; font-variant-numeric: tabular-nums; }.member-arrow { color: #d8ccd1; font-size: 31rpx; font-weight: 400; line-height: 1; }.member-bind-button { width: 126rpx !important; min-width: 126rpx !important; height: 62rpx; justify-self: end; padding: 0; border: 1rpx solid rgba(255,255,255,.2); border-radius: 20rpx; background: linear-gradient(105deg,#e14c7d 0%,#f0848b 100%); color: #fff; font-size: 20rpx; font-weight: 700; line-height: 62rpx; box-shadow: 0 9rpx 20rpx rgba(225,76,125,.24); }.member-bind-button[disabled] { opacity: .65; }.member-strip-pressed { opacity: .88; }
.metrics { min-height: 124rpx; margin-top: 20rpx; padding: 22rpx 0; display: grid; grid-template-columns: repeat(3,1fr); text-align: center; }.metrics view { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5rpx; }.metrics view + view { border-left: 1rpx solid var(--line); }.metrics b { color: #2d2930; font-size: 31rpx; font-weight: 650; font-variant-numeric: tabular-nums; }.metrics text { color: var(--weak); font-size: 18rpx; }
.service-section { margin-top: 34rpx; }.service-head { min-height: 76rpx; display: flex; align-items: center; justify-content: space-between; }.service-head text { font-size: 30rpx; font-weight: 500; }.service-head small { color: #a08d94; font-size: 19rpx; font-weight: 400; }
.menu { padding: 4rpx 20rpx; overflow: hidden; background: rgba(255,254,254,.9); box-shadow: 0 12rpx 32rpx rgba(170,82,111,.07); }.menu button { width: 100% !important; min-width: 0 !important; min-height: 106rpx; padding: 0 2rpx; border-bottom: 1rpx solid rgba(225,76,125,.09); border-radius: 0; display: grid; grid-template-columns: 60rpx minmax(0,1fr) 26rpx; align-items: center; gap: 17rpx; background: transparent; color: var(--text); text-align: left; box-shadow: none; transition: background .16s ease, opacity .16s ease; }.menu button:last-child { border-bottom: 0; }.menu button.menu-item-pressed { background: rgba(252,239,243,.58); opacity: .7; }
.menu-icon { width: 60rpx; height: 60rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; }.menu-icon image { width: 28rpx; height: 28rpx; opacity: .78; }.menu-icon.rose { background: #fbeef2; }.menu-icon.blush { background: #fff2f5; }.menu-icon.mint { background: #edf8f4; }.menu-icon.cream { background: #fff6e9; }.menu-icon.gray { background: #f8eff3; }
.menu-copy { min-width: 0; display: flex; align-items: center; }.menu-copy text { color: #2f292c; font-size: 29rpx; font-weight: 500; line-height: 1.25; }.menu-chevron { width: 26rpx; height: 26rpx; opacity: .32; }
