.profile-page { padding-top: 46rpx; }
.profile-head { min-height: 194rpx; padding: 35rpx; display: grid; grid-template-columns: 123rpx minmax(0, 1fr) auto; align-items: center; gap: 23rpx; }
.avatar { width: 123rpx; height: 123rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fceff4; }.avatar image { width: 58rpx; height: 58rpx; }
.identity { min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }.identity > text { overflow: hidden; font-size: 37rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }.identity small { color: #858189; font-size: 25rpx; }
.profile-head button { width: auto !important; min-width: 0 !important; min-height: 85rpx; padding: 0 25rpx; border: 1rpx solid #c42d5d; border-radius: 31rpx; display: flex; align-items: center; background: transparent; color: #c42d5d; font-size: 27rpx; font-weight: 700; }
.profile-head button[disabled] { border-color: #eceef1; color: #918e95; opacity: 1; }
.load-error { min-height: 82rpx; margin-top: 20rpx; padding: 16rpx 22rpx; border-radius: 23rpx; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; background: #fff0ef; color: #9f2d25; font-size: 23rpx; }.load-error button { min-width: 85rpx !important; min-height: 64rpx; padding: 0 18rpx; border-radius: 20rpx; background: #fff; color: #9f2d25; font-size: 23rpx; font-weight: 700; }
.member-strip { min-height: 154rpx; margin-top: 23rpx; padding: 31rpx; border: 1rpx solid #eceef1; border-radius: 31rpx; display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 19rpx; background: #faeef3; color: #1f1e25; }.member-strip > view { display: flex; flex-direction: column; gap: 8rpx; }.member-strip > view > text { font-size: 31rpx; font-weight: 700; }.member-strip small { color: #6f6b72; font-size: 23rpx; }.member-summary { flex-direction: row !important; align-items: center; gap: 6rpx !important; }.member-summary > text { color: #c42d5d; font-size: 27rpx !important; font-weight: 700; }.member-summary image { width: 31rpx; height: 31rpx; }.member-strip-pressed { background: #f7e7ed; }
.metrics { min-height: 142rpx; margin-top: 23rpx; padding: 27rpx 0; display: grid; grid-template-columns: repeat(3, 1fr); text-align: center; }.metrics view { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; }.metrics view + view { border-left: 1rpx solid #f0f1f4; }.metrics b { color: #c42d5d; font-size: 40rpx; font-weight: 700; font-variant-numeric: tabular-nums; }.metrics text { color: #858189; font-size: 23rpx; }
.menu { margin-top: 23rpx; overflow: hidden; }.menu button { width: 100% !important; min-width: 0 !important; min-height: 104rpx; padding: 0 31rpx; border-bottom: 1rpx solid #f0f1f4; display: flex; align-items: center; justify-content: space-between; background: transparent; color: #1f1e25; font-size: 27rpx; text-align: left; }.menu button:last-child { border-bottom: 0; }.menu image { width: 38rpx; height: 38rpx; }
.bind-button { width: 100%; margin-top: 27rpx; }
