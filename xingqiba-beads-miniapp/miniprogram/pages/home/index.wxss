.home-page { padding-top: 24rpx; }
.brand-header { min-height: 206rpx; margin-bottom: 24rpx; display: flex; align-items: center; justify-content: center; }
.brand-inner { width: 560rpx; max-width: 100%; }
.brand-main { display: flex; align-items: center; gap: 20rpx; }
.brand-lockup { width: 310rpx; height: 134rpx; flex: none; }
.brand-copy { min-width: 0; flex: 1; display: flex; flex-direction: column; align-items: flex-start; gap: 7rpx; }
.brand-cn { color: var(--text); font-size: 31rpx; font-weight: 650; line-height: 1.15; white-space: nowrap; }
.brand-en { color: #e45d85; font-size: 21rpx; font-weight: 650; line-height: 1.2; white-space: nowrap; }
.brand-tagline { margin-top: 13rpx; display: flex; align-items: center; gap: 8rpx; color: var(--weak); font-size: 23rpx; font-weight: 500; letter-spacing: .2rpx; white-space: nowrap; }
.brand-sparkle { color: var(--brand-blush); font-size: 23rpx; transform: rotate(12deg); }
.hero { min-height: 456rpx; padding: 32rpx; border-color: rgba(255,255,255,.82); border-radius: 35rpx; display: grid; grid-template-columns: minmax(0, .76fr) minmax(0, 1.24fr); align-items: center; gap: 18rpx; overflow: hidden; background: linear-gradient(145deg, rgba(255,255,255,.9) 0%, rgba(255,255,255,.8) 62%, rgba(255,241,245,.76) 100%); box-shadow: 0 18rpx 50rpx rgba(225,76,125,.09); }
.hero-copy { min-width: 0; display: flex; flex-direction: column; align-items: flex-start; }
.hero-title { font-size: 38rpx; font-weight: 600; letter-spacing: -1rpx; line-height: 1.2; white-space: nowrap; }
.hero-desc { margin-top: 29rpx; color: var(--muted); font-size: 22rpx; font-weight: 400; line-height: 1.52; white-space: pre-line; }
.hero-button { flex: none; width: 188rpx !important; min-width: 0 !important; max-width: 100%; height: 73rpx; margin: 38rpx 0 0; padding: 0 14rpx; display: flex; align-items: center; justify-content: center; gap: 9rpx; border: 0; border-radius: 24rpx; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 24rpx; font-weight: 600; line-height: 1; white-space: nowrap; box-shadow: 0 12rpx 26rpx rgba(225,76,125,.22); }
.hero-button image { width: 35rpx; height: 35rpx; }.hero-button-pressed { background: linear-gradient(105deg, var(--primary-pressed) 0%, #e9707d 100%); }
.hero-media { min-width: 0; height: 342rpx; position: relative; display: grid; grid-template-columns: 1fr 1fr; border-radius: 25rpx; overflow: hidden; }
.hero-media > image { min-width: 0; width: 100%; height: 100%; }
.hero-media > image:first-child, .hero-media > image:nth-child(2) { border-radius: 0; }
.media-arrow { position: absolute; left: 50%; top: 50%; width: 65rpx; height: 65rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255,255,255,.86); border-radius: 50%; background: var(--surface-strong); color: var(--primary); transform: translate(-50%, -50%); box-shadow: 0 10rpx 30rpx rgba(225,76,125,.12); }
.media-arrow image { width: 30rpx; height: 30rpx; }
.shortcuts { margin-top: 24rpx; padding: 12rpx 0; display: flex; align-items: stretch; border-color: rgba(255,255,255,.8); border-radius: 31rpx; overflow: hidden; box-shadow: 0 15rpx 42rpx rgba(225,76,125,.08); }
.shortcut { flex: 1 1 0; width: 0; min-height: 172rpx; margin: 0; padding: 18rpx 7rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 13rpx; border-radius: 0; background: transparent; color: var(--text); text-align: center; }
.shortcut + .shortcut { border-left: 1rpx solid rgba(232,215,222,.58); }
.shortcut-icon { width: 67rpx; height: 67rpx; display: flex; align-items: center; justify-content: center; border-radius: 23rpx; background: var(--primary-soft); }
.shortcut-icon image { width: 34rpx; height: 34rpx; display: block; }
.shortcut-copy { width: 100%; min-width: 0; text-align: center; }
.shortcut text, .shortcut small { display: block; width: 100%; white-space: nowrap; text-align: center; }
.shortcut text { font-size: 24rpx; font-weight: 500; line-height: 31rpx; }
.shortcut small { margin-top: 3rpx; color: #9b979d; font-size: 17rpx; font-weight: 400; line-height: 24rpx; }
.featured-section { margin-top: 40rpx; }.section-action { color: #e987a3; }.section-action image { width: 31rpx; height: 31rpx; }
.featured-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; }
.featured-card { min-width: 0; border: 0; overflow: hidden; border-radius: 19rpx; background: transparent; box-shadow: none; }
.featured-image { width: 100%; height: 231rpx; border-radius: 19rpx 19rpx 0 0; }
.featured-meta { padding: 23rpx 15rpx; }.featured-meta > text { display: block; overflow: hidden; font-size: 25rpx; font-weight: 400; line-height: 1.25; text-overflow: ellipsis; white-space: nowrap; }
.featured-meta small { margin-top: 8rpx; display: block; overflow: hidden; color: var(--weak); font-size: 21rpx; font-weight: 400; line-height: 1.25; text-overflow: ellipsis; white-space: nowrap; }
.featured-state { min-height: 180rpx; padding: 32rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20rpx; color: var(--muted); font-size: 24rpx; text-align: center; }
.featured-state button { min-width: 144rpx !important; min-height: 72rpx; padding: 0 24rpx; border: 1rpx solid rgba(255,255,255,.82); border-radius: 24rpx; background: var(--surface-strong); color: var(--primary); font-size: 23rpx; }
.featured-skeleton { min-height: 326rpx; padding: 0 15rpx 22rpx; pointer-events: none; }
.featured-skeleton view { width: calc(100% + 30rpx); height: 231rpx; margin-left: -15rpx; border-radius: 19rpx 19rpx 0 0; background: #f0f1f3; }
.featured-skeleton text, .featured-skeleton small { display: block; border-radius: 8rpx; background: #f0f1f3; }
.featured-skeleton text { width: 76%; height: 24rpx; margin-top: 22rpx; }.featured-skeleton small { width: 54%; height: 18rpx; margin-top: 12rpx; }
.card-pressed { opacity: .72; }

@media (max-width: 340px) {
  .brand-inner { width: 540rpx; }
  .brand-lockup { width: 290rpx; height: 125rpx; }
  .brand-cn { font-size: 29rpx; }
  .brand-en { font-size: 19rpx; }
  .brand-tagline { font-size: 21rpx; }
  .hero { padding: 27rpx; grid-template-columns: minmax(0,.8fr) minmax(0,1.2fr); }
  .hero-title { font-size: 35rpx; }
  .hero-button { width: 176rpx !important; }
  .shortcut small { font-size: 16rpx; }
}
