.store-page { padding-top: 46rpx; }
.store-visual { min-height: 354rpx; overflow: hidden; border-radius: 38rpx; }.store-visual image { width: 100%; height: 354rpx; }
.store-body { padding: 31rpx; }.store-name { display: block; margin-bottom: 15rpx; font-size: 42rpx; font-weight: 700; line-height: 1.25; }
.store-facts { display: grid; gap: 13rpx; color: #858189; font-size: 27rpx; }.store-facts > view { display: flex; align-items: center; gap: 10rpx; }.store-facts image { width: 31rpx; height: 31rpx; }
.store-actions { margin-top: 27rpx; display: grid; grid-template-columns: repeat(3, 1fr); gap: 15rpx; }.store-actions button { width: 100% !important; min-width: 0 !important; min-height: 92rpx; border: 0; border-radius: 27rpx; display: flex; align-items: center; justify-content: center; background: #fceff4; color: #1f1e25; font-size: 27rpx; font-weight: 650; }
.booking { width: 100%; margin-top: 21rpx; }.booking image { width: 37rpx; height: 37rpx; }
.booking-summary { margin-bottom: 23rpx; padding: 25rpx; border: 1rpx solid #4e8b75; border-radius: 27rpx; display: flex; align-items: center; gap: 19rpx; background: #eef8f4; }.booking-summary > image { width: 38rpx; height: 38rpx; }.booking-summary view { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 6rpx; }.booking-summary b { font-size: 27rpx; }.booking-summary small { color: #858189; font-size: 23rpx; }.booking-summary button { min-width: 92rpx !important; min-height: 70rpx; padding: 0 16rpx; border-radius: 22rpx; background: #fff; color: #6f6b72; font-size: 22rpx; }
.store-error { margin-bottom: 20rpx; padding: 18rpx 22rpx; border-radius: 23rpx; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; background: #fff0ef; color: #9f2d25; font-size: 23rpx; }.store-error button { min-width: 85rpx !important; min-height: 64rpx; padding: 0 18rpx; border-radius: 20rpx; background: #fff; color: #9f2d25; font-size: 23rpx; font-weight: 700; }
.gallery-section { margin-top: 31rpx; }.gallery-head { min-height: 77rpx; display: flex; align-items: center; justify-content: space-between; }.gallery-head > text { font-size: 35rpx; font-weight: 500; }.gallery-head small { color: #858189; font-size: 23rpx; }
.photo-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 15rpx; }.photo-grid image { width: 100%; height: 238rpx; border-radius: 23rpx; }
.modal-layer { position: fixed; z-index: 300; inset: 0; display: flex; align-items: flex-end; background: rgba(20, 16, 18, .52); }.sheet { width: 100%; max-height: calc(100vh - 80rpx); padding: 35rpx 35rpx calc(35rpx + env(safe-area-inset-bottom)); border-radius: 35rpx 35rpx 0 0; overflow-y: auto; background: #fff; }.sheet-head { margin-bottom: 31rpx; display: flex; align-items: center; justify-content: space-between; }.sheet-head > text { font-size: 38rpx; font-weight: 700; }.sheet-head button { width: 85rpx; height: 85rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fceff4; color: #1f1e25; }.sheet-head button image { width: 35rpx; height: 35rpx; }
.field { margin-bottom: 27rpx; display: grid; gap: 13rpx; }.field > text { font-size: 27rpx; font-weight: 700; }.picker-value { min-height: 92rpx; padding: 0 25rpx; border: 1rpx solid #eceef1; border-radius: 27rpx; display: flex; align-items: center; justify-content: space-between; background: #f9fafc; color: #1f1e25; font-size: 27rpx; }.picker-value text { color: #858189; font-size: 38rpx; }.choice-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15rpx; }.choice { width: 100% !important; min-width: 0 !important; min-height: 92rpx; padding: 8rpx; border: 1rpx solid #eceef1; border-radius: 27rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #1f1e25; font-size: 25rpx; }.choice.active { border-color: #c42d5d; background: #fceff4; color: #c42d5d; }
.booking-error { display: block; margin: -8rpx 0 20rpx; color: #b42318; font-size: 23rpx; line-height: 1.5; }
.inline-phone-bind { margin: 4rpx 0 24rpx; padding: 22rpx; border: 1rpx solid #f0d5df; border-radius: 23rpx; display: flex; align-items: center; gap: 18rpx; background: #fcf3f6; }.inline-phone-bind > view { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 5rpx; }.inline-phone-bind text { color: #332f34; font-size: 24rpx; font-weight: 700; }.inline-phone-bind small { color: #858189; font-size: 20rpx; }.inline-phone-bind button { min-width: 142rpx !important; height: 70rpx; padding: 0 20rpx; border: 0; border-radius: 18rpx; background: #c42d5d; color: #fff; font-size: 22rpx; font-weight: 700; line-height: 70rpx; }.inline-phone-bind button::after { border: 0; }
.slot-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 15rpx; }.slot-choice { width: 100% !important; min-width: 0 !important; min-height: 96rpx; padding: 14rpx 18rpx; border: 1rpx solid #eceef1; border-radius: 23rpx; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 5rpx; background: #fff; color: #1f1e25; text-align: left; }.slot-choice text { font-size: 25rpx; font-weight: 650; }.slot-choice small { color: #858189; font-size: 20rpx; }.slot-choice.active { border-color: #e7afc1; background: #faeef3; color: #c42d5d; }.slot-choice.active small { color: #a22b52; }.slot-choice[disabled] { background: #f4f5f7; color: #9a9aa0; opacity: 1; }.slot-state { min-height: 92rpx; padding: 0 22rpx; border-radius: 23rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; background: #f5f6f8; color: #858189; font-size: 23rpx; }.slot-state.error { background: #fff0ef; color: #9f2d25; }.slot-state button { min-width: 92rpx !important; min-height: 62rpx; padding: 0 16rpx; border-radius: 18rpx; background: #fff; color: #9f2d25; font-size: 21rpx; }
