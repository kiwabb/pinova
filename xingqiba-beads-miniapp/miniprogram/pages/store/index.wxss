.store-page { padding-top: 38rpx; }
.store-intro { padding: 10rpx 4rpx 28rpx; display: flex; flex-direction: column; align-items: flex-start; }
.store-kicker { color: #e14c7d; font-size: 19rpx; font-weight: 700; letter-spacing: 3rpx; }
.store-intro-title { margin-top: 10rpx; color: var(--text); font-size: 38rpx; font-weight: 600; line-height: 1.2; }
.store-intro-desc { margin-top: 10rpx; color: var(--weak); font-size: 21rpx; line-height: 1.45; }
.store-overview { overflow: hidden; }
.store-visual { position: relative; height: 330rpx; overflow: hidden; }.store-visual image { width: 100%; height: 330rpx; }
.store-brand-badge { position: absolute; top: 20rpx; left: 22rpx; height: 64rpx; display: flex; align-items: center; gap: 9rpx; }
.store-brand-mark { width: 55rpx; height: 55rpx; flex: none; filter: drop-shadow(0 3rpx 7rpx rgba(0,0,0,.18)); }
.store-brand-copy { display: flex; flex-direction: column; align-items: flex-start; gap: 2rpx; text-shadow: 0 2rpx 7rpx rgba(0,0,0,.42); }.store-brand-copy text { color: #fff; font-size: 18rpx; font-weight: 700; letter-spacing: 1.5rpx; line-height: 1; }.store-brand-copy small { color: rgba(255,255,255,.88); font-size: 13rpx; white-space: nowrap; }
.store-status { position: absolute; left: 22rpx; bottom: 20rpx; padding: 8rpx 15rpx; border-radius: 999rpx; background: rgba(255,255,255,.92); color: #e14c7d; font-size: 17rpx; font-weight: 700; box-shadow: 0 5rpx 18rpx rgba(31,30,37,.1); }
.store-body { padding: 25rpx 27rpx 27rpx; }.store-name { display: block; margin-bottom: 14rpx; font-size: 31rpx; font-weight: 600; line-height: 1.25; }
.store-facts { display: grid; gap: 10rpx; color: var(--muted); font-size: 21rpx; }.store-facts > view { min-width: 0; display: flex; align-items: center; gap: 9rpx; }.store-facts image { width: 25rpx; height: 25rpx; flex: none; }.store-facts text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.store-actions { margin-top: 23rpx; padding-top: 20rpx; border-top: 1rpx solid var(--line); display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; }.store-actions button { width: 100% !important; min-width: 0 !important; height: 66rpx; border: 0; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; gap: 7rpx; background: #f7f7f9; color: #4f4b52; font-size: 20rpx; font-weight: 600; }.store-actions image { width: 25rpx; height: 25rpx; opacity: .72; }
.booking { width: 100%; height: 92rpx; margin-top: 18rpx; border-radius: 26rpx; font-size: 24rpx; }.booking image { width: 31rpx; height: 31rpx; }
.booking-summary { margin-top: 18rpx; padding: 20rpx 22rpx; border: 1rpx solid #b8ded0; border-radius: 24rpx; display: flex; align-items: center; gap: 15rpx; background: #eef8f4; }.booking-summary > image { width: 32rpx; height: 32rpx; }.booking-summary view { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 4rpx; }.booking-summary b { font-size: 22rpx; }.booking-summary small { color: #71877e; font-size: 19rpx; }.booking-summary button { min-width: 80rpx !important; min-height: 58rpx; padding: 0 14rpx; border-radius: 18rpx; background: #fff; color: #6f6b72; font-size: 19rpx; }
.store-error { margin-top: 18rpx; padding: 17rpx 20rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; background: #fff0ef; color: #9f2d25; font-size: 20rpx; }.store-error button { min-width: 78rpx !important; min-height: 56rpx; padding: 0 16rpx; border-radius: 17rpx; background: #fff; color: #9f2d25; font-size: 19rpx; font-weight: 700; }
.store-highlights { min-height: 128rpx; margin-top: 20rpx; padding: 22rpx 0; display: grid; grid-template-columns: repeat(3,1fr); }
.store-highlights > view { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5rpx; }
.store-highlights > view + view { border-left: 1rpx solid var(--line); }
.store-highlights b { color: #2d2930; font-size: 27rpx; font-weight: 650; }
.store-highlights small { color: var(--weak); font-size: 17rpx; }
.gallery-section { margin-top: 32rpx; }.gallery-head { min-height: 76rpx; display: flex; align-items: center; justify-content: space-between; }.gallery-head > view { display: flex; flex-direction: column; gap: 4rpx; }.gallery-head > view > text { font-size: 29rpx; font-weight: 600; }.gallery-head small { color: var(--weak); font-size: 18rpx; }.gallery-head > text { color: var(--weak); font-size: 19rpx; }
.photo-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; }.photo { width: 100%; height: 210rpx; border-radius: 20rpx; }.photo-0 { grid-column: 1 / -1; height: 290rpx; }
.modal-layer { position: fixed; z-index: 300; inset: 0; display: flex; align-items: flex-end; background: rgba(20,16,18,.46); }.sheet { width: 100%; max-height: calc(100vh - 80rpx); padding: 29rpx 29rpx calc(29rpx + env(safe-area-inset-bottom)); border-radius: 31rpx 31rpx 0 0; overflow-y: auto; background: var(--surface-strong); box-shadow: 0 -18rpx 56rpx rgba(225,76,125,.12); }.sheet-head { margin-bottom: 25rpx; display: flex; align-items: center; justify-content: space-between; }.sheet-head > text { font-size: 31rpx; font-weight: 650; }.sheet-head button { width: 66rpx; height: 66rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fceff3; color: var(--text); }.sheet-head button image { width: 29rpx; height: 29rpx; }
.field { margin-bottom: 23rpx; display: grid; gap: 11rpx; }.field > text { font-size: 23rpx; font-weight: 650; }.picker-value { min-height: 78rpx; padding: 0 21rpx; border: 1rpx solid var(--control-border); border-radius: 23rpx; display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,.68); color: var(--text); font-size: 23rpx; }.picker-value text { color: var(--muted); font-size: 32rpx; }.choice-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 11rpx; }.choice { width: 100% !important; min-width: 0 !important; min-height: 78rpx; padding: 7rpx; border: 1rpx solid var(--control-border); border-radius: 23rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.72); color: var(--text); font-size: 22rpx; }.choice.active { border-color: #e7afc1; background: var(--primary-soft); color: var(--primary); }
.booking-error { display: block; margin: -8rpx 0 20rpx; color: #b42318; font-size: 23rpx; line-height: 1.5; }
.inline-phone-bind { margin: 4rpx 0 24rpx; padding: 22rpx; border: 1rpx solid #f0d5df; border-radius: 23rpx; display: flex; align-items: center; gap: 18rpx; background: #fcf3f6; }.inline-phone-bind > view { min-width: 0; flex: 1; display: flex; flex-direction: column; gap: 5rpx; }.inline-phone-bind text { color: #332f34; font-size: 24rpx; font-weight: 700; }.inline-phone-bind small { color: var(--muted); font-size: 20rpx; }.inline-phone-bind button { min-width: 142rpx !important; height: 70rpx; padding: 0 20rpx; border: 0; border-radius: 18rpx; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 22rpx; font-weight: 700; line-height: 70rpx; box-shadow: 0 9rpx 20rpx rgba(225,76,125,.18); }.inline-phone-bind button::after { border: 0; }
.slot-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 15rpx; }.slot-choice { width: 100% !important; min-width: 0 !important; min-height: 96rpx; padding: 14rpx 18rpx; border: 1rpx solid var(--control-border); border-radius: 23rpx; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 5rpx; background: #fff; color: var(--text); text-align: left; }.slot-choice text { font-size: 25rpx; font-weight: 650; }.slot-choice small { color: var(--muted); font-size: 20rpx; }.slot-choice.active { border-color: #e7afc1; background: #faeef3; color: #e14c7d; }.slot-choice.active small { color: #a22b52; }.slot-choice[disabled] { background: #f4f5f7; color: #9a9aa0; opacity: 1; }.slot-state { min-height: 92rpx; padding: 0 22rpx; border-radius: 23rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; background: #f5f6f8; color: var(--muted); font-size: 23rpx; }.slot-state.error { background: #fff0ef; color: #9f2d25; }.slot-state button { min-width: 92rpx !important; min-height: 62rpx; padding: 0 16rpx; border-radius: 18rpx; background: #fff; color: #9f2d25; font-size: 21rpx; }
