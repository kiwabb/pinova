.editor-page { min-height: 100vh; padding: 32rpx 40rpx 52rpx; background: #f7f8fa; }
.toolbar { height: 80rpx; margin-bottom: 20rpx; display: flex; align-items: center; gap: 12rpx; }.toolbar button { flex: none; width: 80rpx !important; min-width: 80rpx !important; height: 80rpx; padding: 0; border: 1rpx solid #eceef1; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; background: #fff; }.toolbar button.active { border-color: #f0c9d7; background: #faeef3; }.toolbar button[disabled] { opacity: .38; }.toolbar image { width: 36rpx; height: 36rpx; }.toolbar .spacer { flex: 1; }
.settings-panel { margin-bottom: 20rpx; padding: 12rpx 22rpx 24rpx; }.setting-row { min-height: 96rpx; border-bottom: 1rpx solid #f0f1f3; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }.setting-row > text { flex: none; color: #5f5b62; font-size: 23rpx; font-weight: 600; }.segments { min-width: 0; display: flex; gap: 7rpx; }.segments button { min-width: 68rpx !important; height: 58rpx; padding: 0 16rpx; border: 0; border-radius: 14rpx; background: #f3f4f6; color: #716d74; font-size: 21rpx; line-height: 58rpx; }.segments button::after { border: 0; }.segments button.active { background: #c42d5d; color: #fff; font-weight: 700; }.segments.compact button { min-width: 92rpx !important; }
.slider-field { padding-top: 19rpx; }.slider-field > view { padding: 0 4rpx; display: flex; align-items: center; justify-content: space-between; }.slider-field text { color: #5f5b62; font-size: 23rpx; font-weight: 600; }.slider-field small { color: #858189; font-size: 21rpx; font-variant-numeric: tabular-nums; }.slider-field slider { margin: 9rpx 0 0; }.apply-button { height: 76rpx; margin-top: 14rpx; border: 0; border-radius: 18rpx; background: #faeef3; color: #c42d5d; font-size: 24rpx; font-weight: 700; line-height: 76rpx; }.apply-button::after { border: 0; }
.title-field { min-height: 90rpx; margin-bottom: 20rpx; padding: 0 23rpx; display: grid; grid-template-columns: auto minmax(0, 1fr); align-items: center; gap: 20rpx; }.title-field > text { color: #858189; font-size: 23rpx; }.title-field input { width: 100%; height: 82rpx; color: #1f1e25; font-size: 27rpx; text-align: right; }
.canvas-card { position: relative; padding: 16rpx; overflow: hidden; }.canvas-card canvas { width: 100%; height: 640rpx; display: block; background: #fff; }.canvas-status { position: absolute; inset: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx; background: rgba(255, 255, 255, .94); color: #1f1e25; text-align: center; }.canvas-status text { font-size: 27rpx; font-weight: 700; }.canvas-status small { color: #858189; font-size: 22rpx; }.canvas-status.error { color: #b42318; }.canvas-status button { min-width: 130rpx !important; min-height: 76rpx; margin-top: 10rpx; padding: 0 24rpx; border-radius: 18rpx; background: #fceff4; color: #c42d5d; font-size: 25rpx; font-weight: 700; }
.palette { width: 100%; }.palette-row { height: 150rpx; padding: 24rpx 4rpx; display: flex; align-items: center; gap: 18rpx; }.swatch { flex: none; width: 78rpx !important; min-width: 78rpx !important; height: 78rpx; border: 6rpx solid #fff; border-radius: 50%; box-shadow: 0 0 0 1rpx #d9d9dc; }.swatch.active { box-shadow: 0 0 0 5rpx #1f1e25; }
.editor-meta { min-height: 64rpx; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }.editor-meta > text { color: #858189; font-size: 22rpx; }.editor-meta button { min-width: 132rpx !important; height: 60rpx; padding: 0 14rpx; border: 0; background: transparent; color: #c42d5d; font-size: 22rpx; font-weight: 700; line-height: 60rpx; }.editor-meta button::after { border: 0; }
.stats-panel { margin: 8rpx 0 22rpx; padding: 8rpx 22rpx; }.stat-row { min-height: 88rpx; border-bottom: 1rpx solid #f0f1f3; display: grid; grid-template-columns: 38rpx minmax(0,1fr) auto; align-items: center; gap: 15rpx; }.stat-row:last-child { border-bottom: 0; }.stat-row i { width: 34rpx; height: 34rpx; border: 1rpx solid #dedee2; border-radius: 50%; }.stat-row > view { min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }.stat-row text { color: #333138; font-size: 23rpx; font-weight: 600; }.stat-row small { color: #96929a; font-size: 19rpx; }.stat-row b { color: #5f5b62; font-size: 22rpx; font-weight: 600; font-variant-numeric: tabular-nums; }
.tip { display: block; margin-top: 10rpx; color: #858189; font-size: 22rpx; line-height: 1.6; text-align: left; }
.phone-modal { position: fixed; inset: 0; z-index: 30; padding: 40rpx; display: flex; align-items: center; justify-content: center; background: rgba(24, 22, 27, .28); }
.phone-sheet { width: 100%; max-width: 620rpx; padding: 44rpx 36rpx 26rpx; border: 1rpx solid #ececec; border-radius: 28rpx; display: flex; flex-direction: column; align-items: center; background: #fff; box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, .08); text-align: center; }
.phone-sheet-icon { width: 82rpx; height: 82rpx; border-radius: 24rpx; display: grid; place-items: center; background: #faeef3; }.phone-sheet-icon image { width: 40rpx; height: 40rpx; }
.phone-sheet-title { margin-top: 24rpx; color: #222; font-size: 32rpx; font-weight: 700; }.phone-sheet-copy { max-width: 480rpx; margin-top: 12rpx; color: #6e6e73; font-size: 24rpx; line-height: 1.6; }
.phone-bind-button { width: 100% !important; height: 92rpx; margin-top: 32rpx; border: 0; border-radius: 20rpx; background: #c42d5d; color: #fff; font-size: 26rpx; font-weight: 700; line-height: 92rpx; }.phone-bind-button::after,.phone-cancel-button::after { border: 0; }.phone-cancel-button { width: 100% !important; height: 72rpx; margin-top: 8rpx; border: 0; background: transparent; color: #858189; font-size: 24rpx; line-height: 72rpx; }
