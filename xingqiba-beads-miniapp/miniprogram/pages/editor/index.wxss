.top-right { min-width: 0; justify-self: end; padding: 4rpx; border: 1rpx solid rgba(225,76,125,.1); border-radius: 15rpx; display: flex; align-items: center; justify-content: flex-end; gap: 4rpx; background: rgba(255,254,254,.9); box-shadow: 0 8rpx 22rpx rgba(170,82,111,.08); }
.bar-btn { flex: 0 0 48rpx; width: 48rpx !important; min-width: 48rpx !important; height: 48rpx; margin: 0; padding: 0; border: 0; border-radius: 11rpx; background: #fff7fa; display: flex; align-items: center; justify-content: center; box-sizing: border-box; overflow: hidden; }
.bar-btn::after { display: none; }
.bar-btn image { width: 28rpx; height: 28rpx; }
.bar-btn[disabled] { opacity: .35; }
.bar-btn::after { border: 0; }
.bar-btn[disabled] { opacity: .38; }
.bar-btn.primary { background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; box-shadow: 0 8rpx 18rpx rgba(225,76,125,.18); }

/* ── 设置抽屉 ─────────────────────────────── */
.settings-overlay { position: fixed; inset: 0; z-index: 26; display: flex; align-items: flex-end; background: rgba(92,45,64,.22); animation: overlay-in .18s ease-out; }
.settings-sheet { width: 100%; max-width: 750rpx; max-height: 72vh; margin: 0 auto; padding-top: 10rpx; border: 1rpx solid rgba(225,76,125,.14); border-bottom: 0; border-radius: 30rpx 30rpx 0 0; display: flex; flex-direction: column; background: radial-gradient(circle at 88% 0, rgba(248,180,200,.22) 0, rgba(248,180,200,0) 28%), #fffdfd; box-shadow: 0 -24rpx 70rpx rgba(112,48,72,.2); box-sizing: border-box; overflow: hidden; animation: sheet-up .2s ease-out; }
.settings-sheet.source-settings { height: 72vh; }
.settings-sheet.blank-settings { height: 640rpx; max-height: 62vh; }
@keyframes overlay-in { from { background: rgba(92,45,64,0); } to { background: rgba(92,45,64,.22); } }
@keyframes sheet-up { from { transform: translateY(36rpx); opacity: .65; } to { transform: translateY(0); opacity: 1; } }
.settings-handle { flex: none; width: 64rpx; height: 6rpx; margin: 0 auto 12rpx; border-radius: 99rpx; background: linear-gradient(90deg, #f8b4c8 0%, #ed7197 100%); }
.settings-head { flex: none; min-height: 74rpx; padding: 0 24rpx 14rpx; display: flex; align-items: flex-start; justify-content: space-between; border-bottom: 1rpx solid rgba(225,76,125,.1); }
.settings-head > view:first-child { min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.settings-head > view:first-child > text { color: #252126; font-size: 28rpx; font-weight: 700; }
.settings-head small { color: #987b86; font-size: 19rpx; }
.settings-head-actions { flex: none; margin-left: 12rpx; display: flex; align-items: center; gap: 8rpx; }
.settings-head button { flex: none; width: 48rpx !important; min-width: 48rpx !important; height: 48rpx; padding: 0; border: 1rpx solid rgba(225,76,125,.12); border-radius: 50%; background: #fff2f6; color: #b34d70; font-size: 30rpx; line-height: 46rpx; }
.settings-head button::after { border: 0; }
.draft-badge { padding: 5rpx 10rpx; border-radius: 9rpx; background: #faeef3; color: #e14c7d; font-size: 17rpx; font-weight: 700; }
.settings-content { min-height: 0; flex: 1; padding: 20rpx 24rpx 12rpx; box-sizing: border-box; }
.setting-section { margin-bottom: 22rpx; }
.section-label { margin-bottom: 10rpx; color: #59414b; font-size: 21rpx; font-weight: 700; }
.mode-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.mode-btn { min-height: 82rpx; padding: 13rpx 16rpx; border: 1rpx solid rgba(225,76,125,.1); border-radius: 14rpx; display: flex; flex-direction: column; justify-content: center; gap: 3rpx; background: rgba(255,255,255,.88); text-align: left; box-shadow: 0 7rpx 18rpx rgba(170,82,111,.055); box-sizing: border-box; }
.mode-btn::after { border: 0; }
.mode-btn .mode-title { color: #2f2b32; font-size: 22rpx; font-weight: 700; }
.mode-btn .mode-hint { color: #987b86; font-size: 18rpx; }
.mode-btn.active { border-color: rgba(225,76,125,.35); background: linear-gradient(135deg, #fff8fa 0%, #fcecf2 100%); box-shadow: 0 8rpx 22rpx rgba(225,76,125,.1), inset 0 0 0 1rpx rgba(225,76,125,.06); }
.mode-btn.active .mode-title { color: #e14c7d; }
.slider-field { margin-bottom: 22rpx; }
.slider-field slider { margin: 6rpx 0 0; }
.slider-field.disabled { opacity: .55; }
.slider-label { display: flex; justify-content: space-between; align-items: center; }
.slider-label text { color: #59414b; font-size: 22rpx; font-weight: 600; }
.slider-value { color: var(--text) !important; font-variant-numeric: tabular-nums; }
.setting-help { display: block; color: #987b86; font-size: 18rpx; margin: 8rpx 0 10rpx; }
.setting-action-section { margin: 6rpx 0 22rpx; padding-top: 18rpx; border-top: 1rpx solid rgba(225,76,125,.09); }
.section-label-row { margin-bottom: 12rpx; display: flex; align-items: center; justify-content: space-between; }
.section-label-row text { color: #59414b; font-size: 21rpx; font-weight: 700; }
.section-label-row span { padding: 4rpx 9rpx; border-radius: 8rpx; background: #fff0f4; color: #a25f76; font-size: 16rpx; }
.action-row { display: flex; gap: 10rpx; margin: 4rpx 0; flex-wrap: nowrap; }
.act-btn { flex: 1; min-width: 0; min-height: 64rpx; padding: 0 8rpx; border: 1rpx solid rgba(225,76,125,.12); border-radius: 13rpx; background: #fff9fb; color: #513b44; font-size: 20rpx; font-weight: 600; line-height: 64rpx; text-align: center; box-shadow: 0 6rpx 16rpx rgba(170,82,111,.055); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.act-btn::after { border: 0; }
.act-btn[disabled] { opacity: .4; }
.act-btn.full { width: 100% !important; }
.settings-footer { flex: none; padding: 12rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(225,76,125,.1); background: rgba(255,253,253,.98); }
