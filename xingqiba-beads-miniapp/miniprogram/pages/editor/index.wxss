.editor-page { min-height: 100vh; padding: 12rpx 24rpx 180rpx; background: radial-gradient(circle at 88% 0, rgba(248,180,200,.44) 0, rgba(248,180,200,0) 30%), radial-gradient(circle at 0 48%, rgba(252,207,220,.22) 0, rgba(252,207,220,0) 28%), linear-gradient(165deg, #fffefe 0%, #fff7fa 50%, #fffbfc 100%); overflow-x: hidden; }
