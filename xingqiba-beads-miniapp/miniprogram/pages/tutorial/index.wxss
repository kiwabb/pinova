.tutorial-page { padding-top: 35rpx; }
.tutorial-state { min-height: 420rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24rpx; color: #858189; font-size: 25rpx; }.tutorial-state button { min-width: 190rpx; height: 76rpx; padding: 0 28rpx; border: 1rpx solid #e8e8eb; border-radius: 18rpx; background: #fff; color: #c42d5d; font-size: 24rpx; line-height: 76rpx; }.tutorial-state button::after { border: 0; }
.tutorial-head { margin-bottom: 27rpx; display: flex; flex-direction: column; gap: 9rpx; }.tutorial-head > text { font-size: 42rpx; font-weight: 700; }.tutorial-head small { color: #858189; font-size: 25rpx; }
.guide-list { display: grid; gap: 23rpx; }.guide { padding: 15rpx; overflow: hidden; }.guide > image { width: 100%; height: 260rpx; border-radius: 20rpx; }.guide-head { min-height: 108rpx; padding: 15rpx 12rpx 0; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }.guide-head > view { min-width: 0; display: flex; flex-direction: column; gap: 7rpx; }.guide-head > view text { font-size: 29rpx; font-weight: 700; }.guide-head small { color: #858189; font-size: 21rpx; }.guide-toggle { flex: none; color: #c42d5d; font-size: 23rpx; font-weight: 700; }
.steps { margin: 0 12rpx; padding: 8rpx 0 12rpx; border-top: 1rpx solid #f0f1f4; }.steps > view { min-height: 94rpx; padding: 17rpx 0; display: grid; grid-template-columns: 46rpx minmax(0, 1fr); align-items: flex-start; gap: 17rpx; }.steps b { width: 46rpx; height: 46rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fceff4; color: #c42d5d; font-size: 21rpx; }.steps text { color: #5f5b62; font-size: 24rpx; line-height: 1.65; }
.safety-note { margin: 27rpx 0; padding: 25rpx 27rpx; border-radius: 23rpx; display: flex; flex-direction: column; gap: 8rpx; background: #fff7e7; }.safety-note text { font-size: 25rpx; font-weight: 700; }.safety-note small { color: #716b5f; font-size: 22rpx; line-height: 1.6; }
