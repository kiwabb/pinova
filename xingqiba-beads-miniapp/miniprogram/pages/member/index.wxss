.member-page { padding-top: 30rpx; }
.member-state { min-height: 220rpx; padding: 40rpx; display: flex; align-items: center; justify-content: center; color: #858189; font-size: 25rpx; text-align: center; }.member-state.error-state { border-radius: 23rpx; flex-direction: column; gap: 20rpx; background: #fff0ef; color: #9f2d25; }.member-state button { min-width: 130rpx !important; min-height: 76rpx; padding: 0 24rpx; border-radius: 23rpx; background: #fff; color: #9f2d25; font-size: 25rpx; font-weight: 700; }
.member-hero { min-height: 350rpx; padding: 38rpx; border: 1rpx solid #eadce2; border-radius: 31rpx; background: #faeef3; }
.hero-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 24rpx; }
.eyebrow { color: #777279; font-size: 23rpx; }
.level-line { margin-top: 13rpx; display: flex; align-items: baseline; gap: 15rpx; }.level-line > text { color: #c42d5d; font-size: 72rpx; font-weight: 700; line-height: 1; letter-spacing: 0; }.level-line small { color: #1f1e25; font-size: 29rpx; font-weight: 600; }
.points { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }.points b { color: #1f1e25; font-size: 42rpx; font-variant-numeric: tabular-nums; }.points small { color: #777279; font-size: 21rpx; }
.progress-track { height: 12rpx; margin-top: 52rpx; overflow: hidden; border-radius: 999rpx; background: rgba(196, 45, 93, .12); }.progress-track view { min-width: 12rpx; height: 100%; border-radius: inherit; background: #c42d5d; }
.progress-copy { margin-top: 17rpx; display: flex; justify-content: space-between; gap: 20rpx; color: #777279; font-size: 22rpx; }
.compact-head { margin-top: 35rpx; }.section-note { color: #918e95; font-size: 23rpx; }
.tier-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12rpx; }
.tier-item { width: 100% !important; min-width: 0 !important; min-height: 158rpx; padding: 20rpx 6rpx; border: 1rpx solid #eceef1; border-radius: 23rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; color: #1f1e25; }.tier-item > text { font-size: 31rpx; font-weight: 700; }.tier-item small { margin-top: 4rpx; color: #777279; font-size: 20rpx; }.tier-item i { margin-top: 13rpx; color: #a19da3; font-size: 18rpx; font-style: normal; white-space: nowrap; }.tier-item.selected { border-color: #e7afc1; background: #faeef3; color: #c42d5d; }.tier-item.selected i { color: #c42d5d; }.tier-pressed { opacity: .72; }
.benefit-card { margin-top: 23rpx; padding: 31rpx; }
.benefit-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }.benefit-head > view { min-width: 0; display: flex; flex-direction: column; gap: 9rpx; }.benefit-head > view > text { font-size: 31rpx; font-weight: 700; }.benefit-head small { color: #777279; font-size: 22rpx; line-height: 1.5; }.status-tag { flex: none; padding: 9rpx 15rpx; border-radius: 999rpx; background: #fceff4; color: #c42d5d; font-size: 19rpx; }
.benefit-list { margin-top: 27rpx; border-top: 1rpx solid #f0f1f4; }.benefit-list > view { min-height: 82rpx; display: flex; align-items: center; gap: 17rpx; border-bottom: 1rpx solid #f0f1f4; font-size: 25rpx; }.benefit-list > view:last-child { border-bottom: 0; }.check { width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fceff4; color: #c42d5d; font-size: 21rpx; font-weight: 700; }
.rule-card { margin-top: 23rpx; padding: 27rpx 31rpx; border-radius: 23rpx; background: #f2f3f5; display: flex; flex-direction: column; gap: 12rpx; }.rule-card > text { margin-bottom: 2rpx; font-size: 25rpx; font-weight: 600; }.rule-card small { color: #777279; font-size: 21rpx; line-height: 1.6; }.rule-line { display: grid; grid-template-columns: 10rpx minmax(0,1fr); align-items: start; gap: 13rpx; }.rule-line i { width: 8rpx; height: 8rpx; margin-top: 13rpx; border-radius: 50%; background: #c42d5d; }.rule-note { margin-top: 3rpx; padding-top: 13rpx; border-top: 1rpx solid #e2e3e6; }
.bind-action { margin-top: 27rpx; }
