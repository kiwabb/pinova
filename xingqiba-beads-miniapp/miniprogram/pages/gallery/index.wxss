.gallery-page { padding-top: 24rpx; }
.search { position: relative; height: 78rpx; padding: 0 24rpx 0 69rpx; border-radius: 25rpx; }
.search > image { position: absolute; left: 25rpx; top: 23rpx; width: 31rpx; height: 31rpx; }
.search input { width: 100%; height: 78rpx; color: var(--text); font-size: 23rpx; }
.filter-panel { margin-top: 18rpx; padding: 20rpx 0 18rpx 22rpx; overflow: hidden; }
.filter-group { display: block; }
.filter-group.category-group { margin-top: 15rpx; }
.level-filters,.filters { width: 100%; }
.level-row,.filter-row { display: inline-flex; gap: 9rpx; padding-right: 20rpx; }
.level-chip,.chip { flex: none; width: auto !important; min-width: 76rpx !important; height: 52rpx; padding: 0 17rpx; border: 1rpx solid var(--control-border); border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #f5f5f7; color: #77737b; font-size: 19rpx; font-weight: 600; }
.level-chip.active,.chip.active { border-color: transparent; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; box-shadow: 0 7rpx 18rpx rgba(225,76,125,.18); }
.result-head { min-height: 84rpx; padding: 13rpx 3rpx 8rpx; display: flex; align-items: center; justify-content: space-between; }
.result-head text { color: #2f2b32; font-size: 27rpx; font-weight: 600; }
.result-head small { color: #a09da4; font-size: 19rpx; }
.collection-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.collection { width: 100% !important; min-width: 0 !important; height: 456rpx; display: grid; grid-template-rows: 284rpx 170rpx; overflow: hidden; color: var(--text); text-align: left; }
.collection-pressed { opacity: .72; }
.cover { position: relative; height: 284rpx; padding: 11rpx; display: grid; grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); gap: 9rpx; border-bottom: 1rpx solid var(--control-border); }
.cover-cell { min-width: 0; min-height: 0; overflow: hidden; border-radius: 9rpx; background: rgba(255,255,255,.78); }
.cover-cell image { width: 100%; height: 100%; display: block; }
.cover.cover-single { padding: 0; grid-template-columns: 1fr; grid-template-rows: 1fr; gap: 0; }
.cover-single .cover-cell { border-radius: 0; }
.level-badge { position: absolute; top: 15rpx; right: 15rpx; min-width: 56rpx; height: 38rpx; padding: 0 11rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(105deg, var(--primary) 0%, var(--primary-end) 100%); color: #fff; font-size: 17rpx; font-weight: 700; box-shadow: 0 6rpx 14rpx rgba(225,76,125,.18); }
.collection-info { min-height: 0; height: 170rpx; padding: 20rpx 18rpx; display: grid; grid-template-columns: minmax(0, 1fr) 28rpx; align-items: center; gap: 10rpx; overflow: hidden; }
.collection-copy { min-width: 0; overflow: hidden; }.title-line { min-width: 0; display: flex; align-items: center; gap: 7rpx; }
.title-line > text:first-child { min-width: 0; overflow: hidden; font-size: 25rpx; font-weight: 600; line-height: 1.3; text-overflow: ellipsis; white-space: nowrap; }
.private { flex: none; min-height: 46rpx; padding: 0 13rpx; display: flex; align-items: center; border-radius: 999rpx; background: #fceff3; color: #e14c7d; font-size: 19rpx; font-weight: 700; }
.collection-copy small { margin-top: 6rpx; display: block; overflow: hidden; color: var(--weak); font-size: 18rpx; font-weight: 400; line-height: 1.3; text-overflow: ellipsis; white-space: nowrap; }
.pattern-count { margin-top: 8rpx; display: block; color: #e14c7d; font-size: 17rpx; font-weight: 600; }
.chevron { width: 28rpx; height: 28rpx; opacity: .58; }
.error-state { display: flex; flex-direction: column; align-items: center; gap: 20rpx; color: #9f2d25; }.error-state button { min-width: 130rpx !important; min-height: 76rpx; padding: 0 24rpx; border-radius: 23rpx; background: #fceff3; color: #e14c7d; font-size: 25rpx; font-weight: 700; }
.load-more { width: 100% !important; min-height: 78rpx; margin-top: 24rpx; border: 1rpx solid var(--border); border-radius: 23rpx; background: var(--surface-strong); color: var(--primary); font-size: 22rpx; font-weight: 600; }.load-more[disabled] { opacity: .5; }
.list-end { padding: 34rpx 0 8rpx; color: #a09da4; font-size: 21rpx; text-align: center; }
