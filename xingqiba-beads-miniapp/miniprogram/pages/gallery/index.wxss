.gallery-page { padding-top: 46rpx; }
.search { position: relative; height: 94rpx; padding: 0 31rpx 0 85rpx; border-radius: 31rpx; }
.search > image { position: absolute; left: 29rpx; top: 27rpx; width: 38rpx; height: 38rpx; }
.search input { width: 100%; height: 94rpx; color: #1f1e25; font-size: 31rpx; }
.level-filters { width: calc(100vw - 40rpx); margin: 27rpx -40rpx 0 0; }
.level-row { display: flex; gap: 15rpx; padding-right: 40rpx; }
.level-chip { flex: none; width: auto !important; min-width: 108rpx !important; height: 69rpx; padding: 0 25rpx; border: 1rpx solid #eceef1; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #f1f2f4; color: #6f6b72; font-size: 27rpx; font-weight: 600; }
.level-chip.active { border-color: #c42d5d; background: #c42d5d; color: #fff; box-shadow: 0 8rpx 20rpx rgba(196, 45, 93, .14); }
.filters { width: calc(100vw - 40rpx); margin: 19rpx -40rpx 0 0; }
.filter-row { display: flex; gap: 15rpx; padding: 0 40rpx 35rpx 0; }
.chip { flex: none; width: auto !important; min-width: 0 !important; height: 77rpx; padding: 0 31rpx; border: 1rpx solid #eceef1; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #858189; font-size: 31rpx; font-weight: 650; }
.chip.active { border-color: #e34272; background: #c42d5d; color: #fff; }
.collection-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 31rpx; }
.collection { width: 100% !important; min-width: 0 !important; height: 525rpx; display: grid; grid-template-rows: 323rpx 200rpx; overflow: hidden; color: #1f1e25; text-align: left; }
.collection-pressed { opacity: .72; }
.cover { position: relative; height: 323rpx; padding: 15rpx; display: grid; grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(2, 1fr); gap: 15rpx; border-bottom: 1rpx solid #eceef1; }
.cover-cell { min-width: 0; min-height: 0; overflow: hidden; border-radius: 10rpx; background: rgba(255, 255, 255, .78); }
.cover-cell image { width: 100%; height: 100%; }
.level-badge { position: absolute; top: 19rpx; right: 19rpx; min-width: 67rpx; height: 48rpx; padding: 0 13rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center; background: #c42d5d; color: #fff; font-size: 22rpx; font-weight: 700; box-shadow: 0 7rpx 15rpx rgba(31, 30, 37, .14); }
.collection-info { min-height: 0; height: 200rpx; padding: 31rpx; display: grid; grid-template-columns: minmax(0, 1fr) 38rpx; align-items: center; gap: 23rpx; overflow: hidden; }
.collection-copy { min-width: 0; overflow: hidden; }.title-line { min-width: 0; display: flex; align-items: center; gap: 7rpx; }
.title-line > text:first-child { min-width: 0; overflow: hidden; font-size: 33rpx; font-weight: 700; line-height: 1.35; text-overflow: ellipsis; white-space: nowrap; }
.private { flex: none; min-height: 46rpx; padding: 0 13rpx; display: flex; align-items: center; border-radius: 999rpx; background: #fceff4; color: #c42d5d; font-size: 19rpx; font-weight: 700; }
.collection-copy small { margin-top: 8rpx; display: -webkit-box; overflow: hidden; color: #858189; font-size: 23rpx; font-weight: 400; line-height: 1.45; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.chevron { width: 38rpx; height: 38rpx; }
.error-state { display: flex; flex-direction: column; align-items: center; gap: 20rpx; color: #9f2d25; }.error-state button { min-width: 130rpx !important; min-height: 76rpx; padding: 0 24rpx; border-radius: 23rpx; background: #fceff4; color: #c42d5d; font-size: 25rpx; font-weight: 700; }
.load-more { width: 100% !important; min-height: 88rpx; margin-top: 28rpx; border: 1rpx solid #eceef1; border-radius: 23rpx; background: #fff; color: #c42d5d; font-size: 24rpx; font-weight: 650; }.load-more[disabled] { opacity: .5; }
.list-end { padding: 34rpx 0 8rpx; color: #a09da4; font-size: 21rpx; text-align: center; }
