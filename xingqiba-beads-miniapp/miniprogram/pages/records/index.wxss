.records-page { padding-top: 35rpx; }
.records-head { min-height: 94rpx; display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }.records-head > text { font-size: 42rpx; font-weight: 700; }.records-head small { color: var(--weak); font-size: 23rpx; }
.record-state { min-height: 300rpx; padding: 40rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24rpx; color: var(--muted); font-size: 25rpx; text-align: center; }.record-state button { min-width: 180rpx !important; min-height: 82rpx; padding: 0 27rpx; border: 1rpx solid var(--control-border); border-radius: 27rpx; background: #fff; color: #e14c7d; font-size: 25rpx; font-weight: 700; }.record-state.error-state { border-radius: 23rpx; background: #fff0ef; color: #9f2d25; }
.record-list { display: grid; gap: 20rpx; }.record-card { min-height: 150rpx; padding: 18rpx; display: grid; grid-template-columns: 116rpx minmax(0, 1fr) auto; align-items: center; gap: 20rpx; }.record-pressed { opacity: .72; }.record-image, .booking-date { width: 116rpx; height: 116rpx; border-radius: 20rpx; background: #f2f3f5; }.record-image { border: 1rpx solid var(--control-border); }.unavailable-image { display: grid; place-items: center; background: #f3f4f6; }.unavailable-image image { width: 38rpx; height: 38rpx; opacity: .5; }.booking-date { padding: 14rpx 8rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; text-align: center; }.booking-date b { font-size: 22rpx; }.booking-date small { color: var(--muted); font-size: 19rpx; }
.record-copy { min-width: 0; display: flex; flex-direction: column; gap: 9rpx; }.record-copy text { overflow: hidden; font-size: 29rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }.record-copy small { overflow: hidden; color: var(--muted); font-size: 22rpx; text-overflow: ellipsis; white-space: nowrap; }.record-copy .unavailable-reason { color: #9a626e; }.remove-button { min-width: 96rpx !important; min-height: 88rpx; padding: 0 18rpx; border: 1rpx solid var(--control-border); border-radius: 23rpx; background: #fff; color: var(--muted); font-size: 22rpx; }.remove-button[disabled] { opacity: .45; }
.load-more { width: 100% !important; min-height: 88rpx; margin-top: 24rpx; border: 1rpx solid var(--control-border); border-radius: 23rpx; background: #fff; color: #e14c7d; font-size: 24rpx; font-weight: 650; }.load-more[disabled] { opacity: .5; }
.records-end { padding: 30rpx 0 8rpx; color: #a09da4; font-size: 21rpx; text-align: center; }
